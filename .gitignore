gitignore# ==========================================
# 1. Environment Variables & Secrets (CRITICAL)
# ==========================================
.env
.env.local
.env.*.local
*.env
*.pem
*.key
*.cert

# ==========================================
# 2. Dependencies & Package Managers
# ==========================================
node_modules/
jspm_packages/
web_modules/
.pnp
.pnp.js
.venv/
venv/
env/
lib/
lib64/

# ==========================================
# 3. Build Outputs, Logs, & Caches
# ==========================================
dist/
build/
out/
target/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.parcel-cache
.turbo/
.nuxt/
.next/

# ==========================================
# 4. IDE / Editor Configurations
# ==========================================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# ==========================================
# 5. Operating System Metadata
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini